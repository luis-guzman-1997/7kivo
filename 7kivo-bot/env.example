# WhatsApp Meta API (optional if configured from web dashboard)
VERSION_META_WHATSAPP=v21.0
PHONE_NUMBER_WHATSAPP=your_phone_number_id
TOKEN_META_WHATSAPP=your_access_token
VERIFY_META_TOKEN=your_verify_token

# Server
PORT=3005

# Firebase
FIREBASE_PROJECT_ID=kivo7-app
# Organization ID (must exist in 'organizations' collection)
ORG_ID=your_org_id
# Local: ruta al archivo JSON de Service Account
GOOGLE_APPLICATION_CREDENTIALS=./kivo7.json
# Produccion (Railway/etc): usa FIREBASE_SERVICE_ACCOUNT con el JSON completo
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"kivo7-app",...}
